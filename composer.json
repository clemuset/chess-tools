{
    "name": "cmuset/chess-tools",
    "description": "A chess tools library for parsing and exporting chess notations (PGN, SAN, FEN).",
    "keywords": ["chess", "tool", "pgn", "parser", "fen", "san", "validator", "applier"],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Cmuset\\ChessTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cmuset\\ChessTools\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3",
        "friendsofphp/php-cs-fixer": "^3.87",
        "phpstan/phpstan": "^2.1"
    }
}
